ENV_HOST=127.0.0.1
ENV_HOST_TCP_PORT=65432
ENV_HOST_UDP_PORT=65433
ENV_HOST_TLS_PORT=65434
ENV_MAX_NUM_CONNECTIONS=5
ENV_LOG_LEVEL=INFO
ENV_CERT_DIR=certs
ENV_CERT_FILE=server.crt   
ENV_KEY_FILE=server.key
ENV_LOG_DIR=logs
ENV_LOG_FILE=server.log
ENV_JWT_SECRET= JWT_SECRET_KEY_ABCDEFGHIJKLMNOPQRSTUVWXYZ
ENV_JWT_ALGORITHM=HS256
ENV_JWT_EXPIRATION=3600
ENV_MAX_PAYLOAD=32